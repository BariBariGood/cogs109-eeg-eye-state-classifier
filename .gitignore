# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Executed-notebook artifacts (we commit canonical .ipynb only)
*.executed.ipynb

# Local-only poster preview (regenerated on demand by scripts/build_poster.py)
poster/poster_preview.png

# LaTeX build artifacts (we commit final_report.tex and final_report.pdf only)
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.fls
report/*.fdb_latexmk
report/*.synctex.gz
